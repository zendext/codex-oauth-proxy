# Optional Docker Compose overrides for codex-oauth-proxy.
#
# Copy this file to `.env` only when you want to override the defaults used by
# docker-compose.yml.

# CODEX_OAUTH_PROXY_IMAGE=codex-oauth-proxy:latest
# CODEX_OAUTH_PROXY_CONFIG_PATH=./config.yaml
# CODEX_OAUTH_PROXY_AUTH_PATH=./auths

# Build metadata overrides used by docker-build.sh and docker-build.ps1.
# VERSION=dev
# COMMIT=none
# BUILD_DATE=unknown
